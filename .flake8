[flake8]
max-line-length = 120
ignore = E203,W503,E402,E501,W293
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .mypy_cache,
    .venv,
    venv,
    build,
    dist,
    site,
    references,
    qitos.egg-info,
    docs/reference/api_generated,
    docs/zh/reference/api_generated,
    qitos/benchmark/tau_bench/port/envs/*/tasks*.py
